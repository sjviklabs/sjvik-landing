---
---
<section class="relative min-h-[85vh] flex items-center justify-center pt-16">
  <!-- Ambient glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-emerald/5 rounded-full blur-[120px]"></div>

  <div class="relative max-w-5xl mx-auto px-6 text-center">
    <!-- Logo -->
    <div class="mb-8">
      <img src="/logo.png" alt="SJVIK Labs" class="w-28 h-28 mx-auto rounded-2xl emerald-glow" />
    </div>

    <!-- Terminal intro -->
    <div class="inline-block mb-6 px-4 py-2 rounded bg-layer-1 font-mono text-sm text-text-outline">
      <span class="text-emerald">$</span> whoami
      <span class="ml-2 text-text-primary">steven.vik</span>
      <span class="mx-2 text-text-dim">|</span>
      <span class="text-emerald">cybersecurity</span>
      <span class="mx-1 text-text-dim">&middot;</span>
      <span class="text-emerald">devops</span>
      <span class="mx-1 text-text-dim">&middot;</span>
      <span class="text-emerald">creator</span>
    </div>

    <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-4">
      Secure systems. Measured outcomes.
    </h1>
    <p class="text-xl text-text-variant max-w-2xl mx-auto mb-6 leading-relaxed">
      8+ years across enterprise NOC monitoring, incident response, and compliance.
      I build security tools, homelab infrastructure, and practical guides for practitioners.
    </p>

    <!-- Availability -->
    <div class="inline-block mb-8 px-5 py-2.5 rounded bg-emerald/8 text-emerald font-mono text-sm font-medium">
      Available for cybersecurity, DevOps, and infrastructure roles
    </div>

    <!-- Hero metrics -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-px bg-text-dim/20 rounded overflow-hidden max-w-2xl mx-auto mb-10">
      <div class="bg-layer-1 p-5 text-center">
        <div class="font-mono text-2xl font-bold text-emerald">40%</div>
        <div class="text-xs text-text-outline mt-1">MTTR reduction via Python automation</div>
      </div>
      <div class="bg-layer-1 p-5 text-center">
        <div class="font-mono text-2xl font-bold text-emerald">3,000+</div>
        <div class="text-xs text-text-outline mt-1">Endpoints monitored in 24/7 SOC</div>
      </div>
      <div class="bg-layer-1 p-5 text-center col-span-2 md:col-span-1">
        <div class="font-mono text-2xl font-bold text-emerald">CJIS</div>
        <div class="text-xs text-text-outline mt-1">Level 4 cleared, NIST 800-53</div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/experience" class="px-6 py-3 cta-gradient text-base font-mono font-semibold rounded text-white hover:opacity-90 transition-opacity">
        View Experience
      </a>
      <a href="/projects" class="px-6 py-3 bg-layer-2 text-text-primary font-mono rounded hover:bg-layer-3 transition-colors">
        Projects
      </a>
      <a href="/guides" class="px-6 py-3 bg-layer-2 text-text-primary font-mono rounded hover:bg-layer-3 transition-colors">
        Guides
      </a>
    </div>
  </div>
</section>
