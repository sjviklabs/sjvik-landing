---
/**
 * Footer — minimal prototype-style bar.
 * Left: copyright + location. Right: version pill + status LED + quick links.
 */
const year = new Date().getFullYear();
---

<footer style="padding: 32px 0 56px; border-top: 1px solid var(--line);">
  <div
    class="page"
    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;"
  >
    <div
      class="mono"
      style="font-size: 11.5px; color: var(--fg-dim); letter-spacing: 0.08em;"
    >
      © {year} steven j. vik · sjvik labs · built &amp; self-hosted · seattle, wa
    </div>

    <div
      class="mono"
      style="font-size: 11.5px; color: var(--fg-dim); display: flex; gap: 18px; align-items: center;"
    >
      <a href="/Steven_Vik_Resume.pdf" style="color: inherit;">résumé</a>
      <a
        href="https://github.com/sjviklabs"
        target="_blank"
        rel="noopener noreferrer"
        style="color: inherit;"
      >
        github
      </a>
      <a
        href="https://www.linkedin.com/in/stevenjvik/"
        target="_blank"
        rel="noopener noreferrer"
        style="color: inherit;"
      >
        linkedin
      </a>
      <span>v2.0</span>
      <span class="accent">● all systems nominal</span>
    </div>
  </div>
</footer>
