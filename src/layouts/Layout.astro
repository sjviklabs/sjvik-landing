---
import '../styles/global.css';
import StoreSync from '../components/react/StoreSync';
import CommandPalette from '../components/react/CommandPalette';
import TweaksPanel from '../components/react/TweaksPanel';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Steve Vik — Cybersecurity & DevOps | SJVIK Labs",
  description = "Cybersecurity engineer and DevOps practitioner. Security tools, infrastructure guides, open-source projects, and case studies by Steven Vik."
} = Astro.props;

const siteUrl = "https://stevenjvik.tech";
const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter+Tight:wght@400;450;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&family=Caveat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    {/*
      Pre-hydration bootstrap. Runs before any CSS paints.
      Reads the same localStorage keys that nanostores use (src/components/react/store.ts)
      and applies data-theme / data-accent / data-variant / data-motion to <html>,
      so CSS variables resolve correctly on the very first paint (no FOUC).
      Post-hydration, <StoreSync /> takes over live attribute updates.
    */}
    <script is:inline>
      (function(){
        try {
          // nanostores/persistent stores values JSON-encoded.
          function read(key, fallback) {
            var raw = localStorage.getItem(key);
            if (raw === null) return fallback;
            try { return JSON.parse(raw); } catch(_) { return raw; }
          }
          var theme   = read('theme',   'auto');
          var accent  = read('accent',  'green');
          var variant = read('variant', 'fieldnotes');
          var motion  = read('motion',  'on');

          var resolved = theme;
          if (theme === 'auto') {
            resolved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          var root = document.documentElement;
          root.setAttribute('data-theme',   resolved);
          root.setAttribute('data-accent',  accent);
          root.setAttribute('data-variant', variant);
          root.setAttribute('data-motion',  motion);

          // Keep auto-theme in sync with OS preference while the user hasn't pinned.
          window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function(ev){
            if (read('theme', 'auto') === 'auto') {
              root.setAttribute('data-theme', ev.matches ? 'light' : 'dark');
            }
          });

          // Interim theme-toggle handler for the legacy Nav button.
          // Stays until Nav.astro is rewritten to match the prototype topbar
          // (uses React + nanostore directly). Cycles auto -> light -> dark
          // and dispatches a synthetic storage event so hydrated nanostores
          // stay in sync with this out-of-band write.
          var MODES = ['auto', 'light', 'dark'];
          function cycle() {
            var cur = read('theme', 'auto');
            var next = MODES[(MODES.indexOf(cur) + 1) % MODES.length];
            var newValue = JSON.stringify(next);
            localStorage.setItem('theme', newValue);
            // Sync nanostores/persistent listeners (they watch the 'storage' event).
            window.dispatchEvent(new StorageEvent('storage', {
              key: 'theme', newValue: newValue, storageArea: localStorage
            }));
            var resolvedNext = next === 'auto'
              ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark')
              : next;
            root.setAttribute('data-theme', resolvedNext);
            updateToggleLabel(next);
          }
          var ICONS = {
            auto:  '<svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>',
            light: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>',
            dark:  '<svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>'
          };
          var LABELS = { auto: 'System', light: 'Light', dark: 'Dark' };
          function updateToggleLabel(mode) {
            var btn = document.getElementById('theme-toggle');
            var lbl = document.getElementById('theme-label');
            if (btn) {
              var svg = btn.querySelector('svg');
              if (svg) svg.outerHTML = ICONS[mode];
              btn.setAttribute('aria-label', 'Theme: ' + LABELS[mode]);
            }
            if (lbl) lbl.textContent = LABELS[mode];
          }
          document.addEventListener('DOMContentLoaded', function(){
            updateToggleLabel(read('theme', 'auto'));
            var btn = document.getElementById('theme-toggle');
            if (btn) btn.addEventListener('click', cycle);
          });
        } catch(e) { /* no-op: fail open to dark default */ }
      })();
    </script>
  </head>
  <body class="bg-ink text-fg font-[Inter_Tight,sans-serif] antialiased">
    {/* Skip-to-main-content link for keyboard users. Styled to appear only on focus. */}
    <a
      href="#main"
      class="skip-link"
      style="position: absolute; left: -9999px; top: 16px; z-index: 200; padding: 8px 14px; background: var(--green); color: var(--ink); font-family: var(--font-mono); font-size: 13px; border-radius: 4px; text-decoration: none;"
      onfocus="this.style.left='16px'"
      onblur="this.style.left='-9999px'"
    >
      Skip to main content
    </a>

    <slot />

    {/* Global React islands: live state sync, ⌘K palette, tweaks panel. */}
    <StoreSync client:load />
    <CommandPalette client:load />
    <TweaksPanel client:idle />
  </body>
</html>
