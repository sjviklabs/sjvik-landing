---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "SJVIK Labs — Security Tools, Lab Guides & Digital Products",
  description = "Open-source security tools, homelab guides, and digital products by Steven Vik. Cybersecurity engineer, DevOps practitioner, and digital creator."
} = Astro.props;

const siteUrl = "https://sjvik-labs.stevenjvik.tech";
const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- OG Meta -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
  </head>
  <body class="bg-sjvik-bg text-sjvik-text font-[Inter,sans-serif] antialiased" style="background-color: #0D1117;">
    <slot />
  </body>
</html>
