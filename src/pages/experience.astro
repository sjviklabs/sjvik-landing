---
/**
 * /experience — full professional timeline.
 *
 * Content source: src/data/content.ts (EXPERIENCE, EDUCATION, CERTS_ACTIVE,
 * CERTS_EXAM_READY). Renders using the same .section / .section-head /
 * .frame / .tag patterns as the home WorkSection, but lays out every role
 * plus education + both cert buckets (active + exam-ready).
 */
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import {
  EXPERIENCE,
  EDUCATION,
  CERTS_ACTIVE,
  CERTS_EXAM_READY,
  CONTACT,
} from "../data/content";
---

<Layout
  title="Experience — Steve Vik"
  description="Professional experience: enterprise NOC operations, DoD compliance, law enforcement IT, and infrastructure auditing."
>
  <Nav />
  <main id="main" tabindex="-1">
    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>experience · full</div>
          <h2>
            Enterprise NOC, DoD compliance, <em>and law enforcement IT.</em>
          </h2>
          <div class="meta mono">{EXPERIENCE.length} roles</div>
        </div>

        <div style="display: grid; gap: 0;">
          {EXPERIENCE.map((e, i) => (
            <article style="display: grid; grid-template-columns: 180px 1fr auto; gap: 32px; padding: 28px 0; border-top: 1px solid var(--line); align-items: start;">
              <div class="mono" style="font-size: 12px; color: var(--fg-dim);">{e.dates}</div>
              <div>
                <div style="font-size: 20px; font-weight: 500; letter-spacing: -0.015em; margin-bottom: 4px;">
                  {e.title}
                </div>
                <div class="dim" style="font-size: 14px; margin-bottom: 12px;">
                  {e.company}{e.via && <span> {e.via}</span>} &middot; {e.location}
                </div>
                <p style="margin: 0 0 12px; color: var(--fg-mute); font-size: 14px; line-height: 1.55;">
                  {e.description}
                </p>
                <div style="display: flex; flex-wrap: wrap; gap: 6px; align-items: center;">
                  {e.tags.map((t) => <span class="tag">{t}</span>)}
                  {e.caseStudyUrl && (
                    <a href={e.caseStudyUrl} class="mono accent" style="font-size: 12px; margin-left: auto;">
                      Case study →
                    </a>
                  )}
                </div>
              </div>
              <div class="mono" style="font-size: 11px; color: var(--fg-dim); text-align: right;">
                #{String(i + 1).padStart(2, "0")}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>education</div>
          <h2>Academic background.</h2>
          <div class="meta mono">{EDUCATION.length} schools</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          {EDUCATION.map((ed) => (
            <div class="frame">
              <div class="frame-head">
                <div class="left"><span>{ed.school}</span></div>
                <span class="mono dim2">{ed.status}</span>
              </div>
              <div class="frame-body">
                <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">{ed.degree}</div>
                <p style="margin: 0; color: var(--fg-mute); font-size: 14px; line-height: 1.55;">
                  {ed.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section" style="border-bottom: 0;">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>credentials</div>
          <h2>Certifications <em>— active + exam-ready.</em></h2>
          <div class="meta mono">
            {CERTS_ACTIVE.length} active · {CERTS_EXAM_READY.length} pending
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px;">
          <div class="frame">
            <div class="frame-head">
              <div class="left"><span>/active</span></div>
              <span class="mono accent">{CERTS_ACTIVE.length}</span>
            </div>
            <div class="frame-body" style="display: flex; flex-wrap: wrap; gap: 6px;">
              {CERTS_ACTIVE.map((c) => <span class="tag on">{c}</span>)}
            </div>
          </div>
          <div class="frame">
            <div class="frame-head">
              <div class="left"><span>/exam-ready</span></div>
              <span class="mono" style="color: var(--amber);">{CERTS_EXAM_READY.length}</span>
            </div>
            <div class="frame-body" style="display: flex; flex-wrap: wrap; gap: 6px;">
              {CERTS_EXAM_READY.map((c) => (
                <span
                  class="tag"
                  style="color: var(--amber); border-color: color-mix(in oklab, var(--amber) 40%, var(--line));"
                >
                  {c}
                </span>
              ))}
            </div>
          </div>
        </div>

        <div style="text-align: center;">
          <a class="cta solid" href={CONTACT.resumeUrl}>
            <span>↓</span> résumé.pdf
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
