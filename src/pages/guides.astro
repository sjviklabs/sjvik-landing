<Layout
  title="Guides, SJVIK Labs"
  description="Practical PDF guides for cybersecurity professionals, infrastructure builders, and Claude Code power users. Built from real production experience."
>
  <Nav />
  <main class="pt-24 pb-16 px-6 relative bg-base">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-16 text-center">
        <p class="font-mono text-emerald text-sm mb-3">// guides</p>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Practical Guides</h1>
        <p class="text-text-variant text-lg max-w-2xl mx-auto">
          No fluff, no theory-only content. Every page comes from production experience. Real configs, real patterns, real lessons learned.
        </p>
      </div>

      <!-- Product Cards -->
      <div class="space-y-16">
        {products.map((product) => (
          <div class="rounded-xl border border-text-dim/20 p-8 shadow-lg" class="bg-layer-1">
            <!-- Title + Price Row -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
              <div>
                <h2 class="text-2xl font-bold mb-1">{product.title}</h2>
                <p class="font-mono text-sm text-text-variant">{product.pages} &middot; PDF</p>
              </div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-2xl font-bold text-emerald">{product.price}</span>
              </div>
            </div>

            <!-- Who it's for -->
            <div class="mb-6 rounded-lg bg-base border border-text-dim/20 px-4 py-3">
              <p class="text-sm"><span class="font-mono text-emerald">Who it's for:</span> <span class="text-text-variant">{product.audience}</span></p>
            </div>

            <!-- Description -->
            <p class="text-text-primary leading-relaxed mb-6">{product.description}</p>

            <!-- Table of Contents -->
            <div class="mb-6">
              <p class="font-mono text-emerald text-sm mb-3">Table of contents:</p>
              <ol class="space-y-1">
                {product.chapters.map((ch, i) => (
                  <li class="flex items-start gap-3 text-sm text-text-primary">
                    <span class="font-mono text-text-variant shrink-0 w-6 text-right">{String(i).padStart(2, '0')}</span>
                    <span>{ch}</span>
                  </li>
                ))}
              </ol>
            </div>

            <!-- Free Sample Chapter -->
            {product.sampleContent && (
              <details class="mb-6 group" open>
                <summary class="cursor-pointer font-mono text-amber text-sm mb-3 flex items-center gap-2 select-none hover:text-amber/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
                  <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                  {product.sampleTitle}, read free, no signup
                </summary>
                <div class="mt-3 rounded-lg border border-amber/30 p-6 text-base leading-relaxed text-text-primary space-y-3" class="bg-lowest" set:html={product.sampleContent} />
              </details>
            )}

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {product.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-1 rounded bg-base text-text-variant border border-text-dim/20">{tag}</span>
              ))}
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-wrap gap-3">
              {product.url !== "URL_PENDING" ? (
                <a
                  href={product.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-6 py-3 cta-gradient text-white font-mono font-semibold rounded-lg hover:cta-gradient-light transition-colors"
                >
                  Get the Guide
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              ) : (
                <span class="inline-flex items-center gap-2 px-6 py-3 border border-emerald/30 text-emerald font-mono font-semibold rounded-lg">
                  Coming soon
                </span>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Note -->
      <div class="mt-16 rounded-xl border border-text-dim/20 p-6" class="bg-layer-1">
        <p class="font-mono text-emerald text-sm mb-2">// a note on pricing</p>
        <p class="text-text-primary leading-relaxed mb-3">
          The cybersecurity and homelab guides launched in beta with a free discount code so early readers could kick the tires and give honest feedback. 42 people grabbed copies. A few sent notes about what worked and what didn't. That feedback made the guides better.
        </p>
        <p class="text-text-primary leading-relaxed mb-3">
          The beta period is over. All guides are at full price now. If you grabbed a free copy and found it useful, leaving a rating on Gumroad is the best way to pay it forward.
        </p>
        <p class="text-text-variant text-sm">
          No email list, no upsell. Read the free sample chapters on the cybersecurity and homelab guides, then decide.
        </p>
      </div>

      <!-- Back to Home -->
      <div class="mt-12 text-center">
        <a href="/" class="font-mono text-sm text-text-variant hover:text-emerald transition-colors">
          &larr; Back to SJVIK Labs
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
