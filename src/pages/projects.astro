---
/**
 * /projects — full project grid with filter tabs by kind.
 *
 * Renders the same ProjectsSection used on the home page, plus a digital
 * products row (guides) below for cross-sell.
 */
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import { GUIDES } from "../data/content";
---

<Layout
  title="Projects — Steve Vik"
  description="Security tools, infrastructure operations, automation, and digital products by Steven Vik."
>
  <Nav />
  <main id="main" tabindex="-1">
    <ProjectsSection />

    <section class="section" style="border-bottom: 0;">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>digital products</div>
          <h2>Guides — <em>built from real production experience.</em></h2>
          <div class="meta mono">{GUIDES.length} titles</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
          {GUIDES.map((g) => (
            <a
              href={g.url}
              target="_blank"
              rel="noopener noreferrer"
              class="tile"
              style="text-decoration: none; color: inherit;"
            >
              <div style="display: flex; justify-content: space-between; align-items: baseline;">
                <span class="mono accent" style="font-size: 16px;">{g.price}</span>
                <span class="tag on">PDF</span>
              </div>
              <div class="tile-title" style="font-size: 16px;">{g.title}</div>
              <div class="tile-desc">{g.description}</div>
              <div class="mono dim2" style="font-size: 11px;">{g.pages}</div>
            </a>
          ))}
        </div>

        <div style="margin-top: 28px; text-align: right;">
          <a href="/guides" class="mono dim" style="font-size: 12px; letter-spacing: 0.04em;">
            sample chapters →
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
