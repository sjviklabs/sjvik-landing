---
/**
 * /about — bio, skills, certifications, education, and contact links.
 *
 * All content sourced from src/data/content.ts (CONTACT, SKILLS, CERTS_*,
 * EDUCATION). Uses the new prototype section/frame/tile/label patterns.
 */
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import {
  CONTACT,
  SKILLS,
  CERTS_ACTIVE,
  CERTS_EXAM_READY,
  EDUCATION,
} from "../data/content";
---

<Layout
  title="About — Steve Vik"
  description="Cybersecurity engineer and DevOps practitioner. Skills, certifications, education, and contact information."
>
  <Nav />
  <main id="main" tabindex="-1">
    {/* BIO — terminal-style quote frame */}
    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>about</div>
          <h2>Steve <em>Vik</em>.</h2>
          <div class="meta mono">{CONTACT.location.toLowerCase()}</div>
        </div>

        <div class="frame marks" style="max-width: 780px;">
          <span class="tr"></span><span class="bl"></span>
          <div class="frame-head">
            <div class="left"><span>steve@sjvik-labs ~</span></div>
            <span class="mono accent">$ cat about.md</span>
          </div>
          <div class="frame-body" style="font-family: var(--font-mono); font-size: 13.5px; line-height: 1.7; color: var(--fg-mute); display: grid; gap: 12px;">
            {CONTACT.bio.map((para) => <p style="margin: 0;">{para}</p>)}
          </div>
        </div>
      </div>
    </section>

    {/* SKILLS — category grid of tag lists */}
    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>skills</div>
          <h2>Technical <em>toolkit.</em></h2>
          <div class="meta mono">
            {SKILLS.reduce((n, g) => n + g.skills.length, 0)} tools
          </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px;">
          {SKILLS.map((g) => (
            <div class="frame">
              <div class="frame-head">
                <div class="left"><span>{g.name.toLowerCase()}</span></div>
                <span class="mono dim2">{g.skills.length}</span>
              </div>
              <div class="frame-body" style="display: flex; flex-wrap: wrap; gap: 6px;">
                {g.skills.map((s) => <span class="tag">{s}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CERTS — active + exam-ready two-column frame */}
    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>credentials</div>
          <h2>Certifications.</h2>
          <div class="meta mono">
            {CERTS_ACTIVE.length} active · {CERTS_EXAM_READY.length} pending
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div class="frame">
            <div class="frame-head">
              <div class="left"><span>/active</span></div>
              <span class="mono accent">{CERTS_ACTIVE.length}</span>
            </div>
            <div class="frame-body" style="display: flex; flex-wrap: wrap; gap: 6px;">
              {CERTS_ACTIVE.map((c) => <span class="tag on">{c}</span>)}
            </div>
          </div>
          <div class="frame">
            <div class="frame-head">
              <div class="left"><span>/exam-ready</span></div>
              <span class="mono" style="color: var(--amber);">{CERTS_EXAM_READY.length}</span>
            </div>
            <div class="frame-body" style="display: flex; flex-wrap: wrap; gap: 6px;">
              {CERTS_EXAM_READY.map((c) => (
                <span
                  class="tag"
                  style="color: var(--amber); border-color: color-mix(in oklab, var(--amber) 40%, var(--line));"
                >
                  {c}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* EDUCATION */}
    <section class="section">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>education</div>
          <h2>Academic background.</h2>
          <div class="meta mono">{EDUCATION.length} schools</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          {EDUCATION.map((ed) => (
            <div class="frame">
              <div class="frame-head">
                <div class="left"><span>{ed.school}</span></div>
                <span class="mono dim2">{ed.status}</span>
              </div>
              <div class="frame-body">
                <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">{ed.degree}</div>
                <p style="margin: 0; color: var(--fg-mute); font-size: 14px; line-height: 1.55;">
                  {ed.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CONTACT */}
    <section class="section" style="border-bottom: 0;">
      <div class="page">
        <div class="section-head">
          <div class="label"><span class="bullet"></span>connect</div>
          <h2>Let's <em>work together.</em></h2>
          <div class="meta mono">&lt; 24h reply</div>
        </div>

        <p style="max-width: 640px; color: var(--fg-mute); font-size: 15px; line-height: 1.6; margin: 0 0 28px;">
          {CONTACT.availability}. If you value measured outcomes, documented
          processes, and someone who's done this work in real enterprise
          environments — let's talk.
        </p>

        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a class="cta solid" href={`mailto:${CONTACT.email}`}>
            <span>✉</span> {CONTACT.email}
          </a>
          <a class="cta" href={CONTACT.linkedin} target="_blank" rel="noopener noreferrer">
            <span>❯</span> LinkedIn
          </a>
          <a class="cta" href={CONTACT.github} target="_blank" rel="noopener noreferrer">
            <span>❯</span> GitHub
          </a>
          <a class="cta ghost" href={CONTACT.resumeUrl}>
            <span>↓</span> résumé.pdf
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
