---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const skillCategories = [
  {
    name: "SIEM & Detection",
    skills: ["Splunk", "SolarWinds", "Blackrock3", "CrowdStrike Falcon", "Defender for Endpoint", "Sentinel"]
  },
  {
    name: "Cloud & Identity",
    skills: ["AWS (EC2, S3, IAM)", "Azure (VMs, Security Center)", "Entra ID", "Defender", "CSPM"]
  },
  {
    name: "Scripting & Automation",
    skills: ["Python", "PowerShell", "Bash", "SQL", "Splunk SPL"]
  },
  {
    name: "Infrastructure",
    skills: ["Linux", "Windows Server", "Proxmox VE", "LXC", "VMware ESXi", "Cisco UC"]
  },
  {
    name: "Network & Security Tools",
    skills: ["Cisco", "Fortinet", "VPN", "Active Directory", "DNS", "DHCP", "Nessus", "Wireshark", "Snort", "Metasploit"]
  },
  {
    name: "Compliance & Frameworks",
    skills: ["NIST 800-53", "NIST CSF", "CJIS", "DISA STIG", "ISO 27001", "ITIL"]
  },
  {
    name: "Security Disciplines",
    skills: ["Incident Response", "Threat Hunting", "Vulnerability Assessment", "Digital Forensics", "Malware Analysis"]
  },
  {
    name: "DevOps & Tooling",
    skills: ["Git", "GitHub", "Terraform", "Ansible", "Node.js / Express", "CI/CD", "ServiceNow"]
  }
];

const activeCerts = [
  "CompTIA Security+", "CompTIA Network+", "CompTIA A+", "ITIL Foundation",
  "Linux Essentials (LPI 010-160)", "CJIS Level 4",
  "Google Cybersecurity Certificate", "Google IT Support Certificate"
];

const examReady = ["CCNA", "CySA+", "PenTest+", "Linux+", "Project+", "SSCP", "CEH"];
---

<Layout
  title="About — Steve Vik"
  description="Cybersecurity engineer and DevOps practitioner. Skills, certifications, education, and contact information."
>
  <Nav />
  <main class="pt-24 pb-16 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Bio -->
      <div class="mb-16">
        <p class="kicker mb-2">// about</p>
        <h1 class="font-display text-3xl sm:text-4xl font-bold mb-6">Steve Vik</h1>

        <div class="bg-layer-1 rounded p-8 max-w-3xl">
          <div class="flex items-center gap-2 mb-6 pb-4 border-b border-text-dim/20">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-3 font-mono text-xs text-text-outline">steve@sjvik-labs ~</span>
          </div>
          <div class="font-mono text-sm leading-relaxed space-y-4">
            <p>
              <span class="text-emerald">$</span>
              <span class="text-text-outline ml-2">cat about.md</span>
            </p>
            <div class="pl-4 space-y-3 text-text-primary">
              <p>Cybersecurity engineer and DevOps practitioner based in the US. I build security tools, run a self-hosted Proxmox homelab, and create practical guides for other practitioners.</p>
              <p>My day job is defending networks and hunting threats. My side projects are the tools and guides I wish existed when I was starting out.</p>
              <p>Everything I ship comes from production experience. No theoretical fluff, no AI-generated filler. Real configs, real patterns, real lessons learned.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills -->
      <div class="mb-16">
        <p class="kicker mb-2">// skills</p>
        <h2 class="font-display text-2xl font-bold mb-6">Technical toolkit</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {skillCategories.map((category) => (
            <div class="bg-layer-1 rounded p-5">
              <h3 class="font-mono text-sm font-semibold text-emerald mb-3">{category.name}</h3>
              <div class="flex flex-wrap gap-1.5">
                {category.skills.map((skill) => (
                  <span class="chip">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Certifications -->
      <div class="mb-16">
        <p class="kicker mb-2">// certifications</p>
        <h2 class="font-display text-2xl font-bold mb-6">Active credentials</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-layer-1 rounded p-5">
            <h3 class="font-mono text-sm font-semibold text-emerald mb-3">Active</h3>
            <div class="flex flex-wrap gap-1.5">
              {activeCerts.map((cert) => (
                <span class="font-mono text-xs font-medium px-3 py-1.5 rounded bg-emerald/8 text-emerald">{cert}</span>
              ))}
            </div>
          </div>
          <div class="bg-layer-1 rounded p-5">
            <h3 class="font-mono text-sm font-semibold text-amber mb-3">Exam Ready</h3>
            <div class="flex flex-wrap gap-1.5">
              {examReady.map((cert) => (
                <span class="font-mono text-xs font-medium px-3 py-1.5 rounded bg-amber/8 text-amber">{cert}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Education -->
      <div class="mb-16">
        <p class="kicker mb-2">// education</p>
        <h2 class="font-display text-2xl font-bold mb-6">Academic background</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-layer-1 rounded p-5">
            <h3 class="font-bold mb-1">B.S. Cybersecurity & Information Assurance</h3>
            <p class="font-mono text-sm text-text-outline mb-2">Western Governors University &middot; In Progress (returning May 2026)</p>
            <p class="text-text-variant text-sm">Competency-based program covering security operations, cryptography, network defense, risk management, and governance. One quarter remaining.</p>
          </div>
          <div class="bg-layer-1 rounded p-5">
            <h3 class="font-bold mb-1">Cybersecurity & Forensics Coursework</h3>
            <p class="font-mono text-sm text-text-outline mb-2">Highline College &middot; 2+ years completed</p>
            <p class="text-text-variant text-sm">Foundation in digital forensics, network security, incident response methodology, and applied security analysis.</p>
          </div>
        </div>
      </div>

      <!-- Connect -->
      <div>
        <p class="kicker mb-2">// connect</p>
        <h2 class="font-display text-2xl font-bold mb-3">Let's work together</h2>
        <p class="text-text-variant mb-6 max-w-xl">
          Available for cybersecurity, DevOps, and IT operations roles.
          If you value measured outcomes, documented processes, and someone who's done this work in real enterprise environments.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="mailto:steven@stevenjvik.tech" class="px-5 py-2.5 cta-gradient text-white font-mono text-sm font-semibold rounded hover:opacity-90 transition-opacity">
            steven@stevenjvik.tech
          </a>
          <a href="https://linkedin.com/in/stevenjvik" target="_blank" rel="noopener" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">
            LinkedIn
          </a>
          <a href="https://github.com/sjviklabs" target="_blank" rel="noopener" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">
            GitHub
          </a>
          <a href="/Steven_Vik_Resume.pdf" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">
            Resume (PDF)
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
