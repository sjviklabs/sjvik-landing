---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const nodes = [
  { role: "Primary compute", name: "Node 1", spec: "64 GB · NVMe + SATA · 7 LXCs", services: ["DNS filtering (AdGuard)", "Reverse proxy (Traefik + TLS)", "Monitoring stack (Grafana, Prometheus, Loki)", "Operator dashboard (React + Express)", "Vault sync", "Password vault (Vaultwarden)"] },
  { role: "AI + Services", name: "Node 2", spec: "64 GB · NVMe + 932 GB SATA · 6 LXCs", services: ["SIEM (Wazuh v4.14)", "Automation agents (Garrison)", "Web analytics (Umami)", "LLM inference (Ollama)", "Uptime monitoring"] },
  { role: "Storage + Backup", name: "Node 3", spec: "64 GB · NVMe + SATA array · 3 LXCs", services: ["Proxmox Backup Server", "Network file shares (Samba)", "Local AI inference"] },
];

const services = [
  {
    label: "Centralized Logging",
    name: "Loki + Alloy Pipeline",
    description: "Grafana Loki v3.7 ingests logs from all 16 containers via Grafana Alloy agents. TSDB v13 schema with 7-day retention. Each agent labels logs with host, container, node, and job for precise filtering. Alloy configs are Ansible-templated — adding a new container to the pipeline is automatic."
  },
  {
    label: "SIEM",
    name: "Wazuh Security Monitoring",
    description: "Full Wazuh deployment (indexer + manager + dashboard) with agents on 12 containers. Provides endpoint monitoring, file integrity monitoring, log analysis, vulnerability detection, and compliance reporting."
  },
  {
    label: "Infrastructure as Code",
    name: "Ansible — 20+ Roles, One Command",
    description: "Every container's desired state is declared in Ansible. A single site.yml playbook converges all 16 containers. Audit-first role authoring ensures roles capture real state, not assumptions. Ansible Vault encrypts all secrets. New containers are provisioned with one command via create-container.yml."
  },
  {
    label: "Operator Dashboard",
    name: "Control Panel — Express + React",
    description: "Custom-built dashboard with 9 pages: infrastructure overview, centralized log search (proxied Loki LogQL), automation agent runs, GTD task management, project hub, and cost tracking. 12 scheduled collector jobs feed data automatically. The Logs page provides container, severity, and time range filtering without needing Grafana access."
  },
  {
    label: "Alerting",
    name: "13 Grafana Alert Rules",
    description: "File-provisioned (GitOps-managed) alert rules covering per-container disk and RAM usage, CPU spikes, node availability, backup compliance, TLS certificate expiry, and SIEM agent health. Triggered by a cluster audit that discovered 3 containers silently overflowing disk with no alerts firing."
  },
  {
    label: "Network Security",
    name: "VLAN Segmentation + DNS Filtering",
    description: "4 VLANs isolate management, services, data, and gaming traffic. The gaming VLAN is fully isolated with no cross-VLAN routing. AdGuard Home provides network-wide DNS filtering and local hostname resolution. Traefik reverse proxy serves all services with locally-trusted TLS certificates."
  }
];

const domains = [
  { num: "01", title: "Infrastructure as Code", desc: "20+ Ansible roles, site.yml converges all 16 containers. Audit-first role authoring prevents codifying drift. Encrypted secrets via Ansible Vault." },
  { num: "02", title: "Centralized Observability", desc: "Every container ships logs to Loki, exports metrics to Prometheus, and is health-checked by Uptime Kuma. 13 Grafana alert rules cover disk, RAM, CPU, backups, and SIEM." },
  { num: "03", title: "Defense in Depth", desc: "4 VLANs, Wazuh SIEM with 12 agents, SSH key-only auth, least-privilege service users, DNS filtering. Gaming VLAN fully isolated." },
  { num: "04", title: "Operational Discipline", desc: "Every change committed. Staggered deployments (serial:3). Conservative roles for critical services. DNS server is always last in any rollout." },
  { num: "05", title: "Disaster Recovery", desc: "Daily PBS backups for all 16 containers. DR smoke test passed — full container restored to a different node in under 10 minutes. Dual Tailscale failover tested." },
  { num: "06", title: "Full-Stack Engineering", desc: "Custom React + Express operator dashboard. Loki LogQL proxy. 12 scheduled collectors. Jinja2 → River/HCL template generation for Alloy configs." },
];

const tech = [
  "Linux", "Proxmox VE", "LXC containers", "Ansible", "TypeScript", "Node.js",
  "React 19", "Express 5", "Python", "Bash", "Grafana", "Prometheus", "Loki",
  "Grafana Alloy", "Wazuh SIEM", "Traefik", "AdGuard DNS", "Tailscale",
  "Vaultwarden", "PostgreSQL", "SQLite", "Git", "SSH"
];
---

<Layout
  title="SJVIK NOC — Steve Vik"
  description="SJVIK NOC: VLAN-segmented 3-node Proxmox operations center for security research, infrastructure automation, and applied engineering."
>
  <Nav />
  <main class="pt-24 pb-16 px-6">
    <div class="max-w-4xl mx-auto">

      <a href="/projects" class="inline-flex items-center gap-1 font-mono text-sm text-text-outline hover:text-emerald transition-colors mb-8">
        <span class="text-emerald opacity-60">cd ../</span> projects
      </a>

      <div class="mb-8">
        <p class="kicker mb-2">Personal Project &middot; Infrastructure Engineering</p>
        <h1 class="font-display text-3xl sm:text-4xl font-bold mb-3">SJVIK Network Operations Center</h1>
        <div class="flex flex-wrap items-center gap-3 font-mono text-sm text-text-outline">
          <span>SJVIK Labs</span>
          <span class="w-px h-3.5 bg-text-dim"></span>
          <span>2024 — present</span>
          <span class="w-px h-3.5 bg-text-dim"></span>
          <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded bg-ok/8 text-ok text-xs font-semibold uppercase tracking-wider">
            <span class="w-1.5 h-1.5 rounded-full bg-ok animate-pulse"></span>
            Online
          </span>
        </div>
      </div>

      <!-- Intro -->
      <div class="bg-layer-1 rounded p-6 mb-12 relative">
        <span class="absolute -top-2.5 left-4 font-mono text-xs font-semibold text-emerald bg-base px-2">// README</span>
        <p class="text-text-variant text-sm leading-relaxed">
          The SJVIK NOC is a production-grade operations center running 16 LXC containers across a 3-node Proxmox HA cluster with 4 VLAN-segmented network zones. Every container ships logs to a centralized Loki instance, exports metrics to Prometheus, and is monitored by 13 Grafana alert rules. All infrastructure is codified in Ansible — new containers are one command. A custom React dashboard provides operator-facing log search, infrastructure health, and automation visibility without requiring Grafana access.
        </p>
        <a href="/noc/" class="inline-flex items-center gap-1 font-mono text-xs text-emerald hover:underline mt-3">
          Full architecture document &rarr;
        </a>
      </div>

      <!-- Cluster topology -->
      <section class="mb-10">
        <p class="kicker mb-2">// infrastructure</p>
        <h2 class="font-display text-xl font-bold mb-4">3-node HA cluster — 16 containers across 4 VLANs</h2>

        <div class="grid md:grid-cols-3 gap-px bg-text-dim/20 rounded overflow-hidden mb-6">
          {nodes.map((node) => (
            <div class="bg-layer-1 p-5">
              <div class="font-mono text-xs font-semibold text-amber uppercase tracking-wider opacity-80 mb-2">{node.role}</div>
              <div class="font-mono font-bold text-text-primary mb-1">{node.name}</div>
              <div class="font-mono text-xs text-text-outline mb-3">{node.spec}</div>
              <ul class="space-y-1">
                {node.services.map((svc) => (
                  <li class="text-text-variant text-sm flex items-baseline gap-2">
                    <span class="font-mono text-xs text-emerald opacity-50">$</span>
                    {svc}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="bg-layer-1 rounded p-5">
          <h3 class="font-mono font-bold text-sm mb-2">cluster.conf</h3>
          <p class="text-text-variant text-sm leading-relaxed mb-3">3-node Proxmox HA cluster with quorum, VLAN-segmented networking, and SSH key-only authentication. 5 critical containers are HA-registered with automatic restart. Dual Tailscale subnet routers provide encrypted remote access with tested failover.</p>
          <div class="flex flex-wrap gap-1.5">
            <span class="chip">HA cluster</span>
            <span class="chip">4 VLANs</span>
            <span class="chip">SSH key mesh</span>
            <span class="chip">Container isolation</span>
            <span class="chip">Quorum</span>
            <span class="chip">Dual VPN failover</span>
          </div>
        </div>
      </section>

      <!-- Services -->
      <section class="mb-10">
        <p class="kicker mb-2">// services</p>
        <h2 class="font-display text-xl font-bold mb-4">What's running and why each service exists</h2>
        {services.map((svc) => (
          <div class="work-item">
            <span class="font-mono text-xs font-semibold text-emerald uppercase tracking-wider opacity-80 mb-2 block">{svc.label}</span>
            <h3 class="font-bold mb-2">{svc.name}</h3>
            <p class="text-text-variant text-sm leading-relaxed">{svc.description}</p>
          </div>
        ))}
      </section>

      <!-- Demonstrates -->
      <section class="mb-10">
        <p class="kicker mb-2">// demonstrates</p>
        <h2 class="font-display text-xl font-bold mb-4">What this project demonstrates</h2>
        <div class="grid md:grid-cols-3 sm:grid-cols-2 gap-px bg-text-dim/20 rounded overflow-hidden">
          {domains.map((d) => (
            <div class="bg-layer-1 p-5 hover:bg-layer-2 transition-colors">
              <div class="font-mono text-xs font-semibold text-amber opacity-70 mb-2">{d.num}</div>
              <h3 class="font-bold text-sm mb-2">{d.title}</h3>
              <p class="text-text-variant text-xs leading-relaxed">{d.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Stack -->
      <section class="mb-10">
        <p class="kicker mb-2">// stack</p>
        <h2 class="font-display text-xl font-bold mb-4">Tools in active production use</h2>
        <div class="bg-layer-1 rounded p-5">
          <div class="flex flex-wrap gap-1.5">
            {tech.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
      </section>

      <div class="flex items-center justify-between flex-wrap gap-3 pt-8 border-t border-text-dim/20">
        <a href="/projects" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">&larr; All Projects</a>
        <div class="flex gap-3">
          <a href="/experience/sound-transit" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">Sound Transit &rarr;</a>
          <a href="/experience/jblm" class="px-5 py-2.5 bg-layer-2 text-text-primary font-mono text-sm rounded hover:bg-layer-3 transition-colors">JBLM &rarr;</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
